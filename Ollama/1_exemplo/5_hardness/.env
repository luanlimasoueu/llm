# Endpoint da API do Ollama (compatível com OpenAI Chat Completions).
# Só muda se o Ollama estiver rodando em outra máquina/porta/container.
OLLAMA_API=http://localhost:11434/v1/chat/completions

# Modelo usado pelo agente principal (o que executa comandos).
# Baixe antes com: ollama pull qwen2.5-coder:7b
OLLAMA_MODEL=qwen2.5-coder:7b

# Modelo usado pelo Judge para avaliar a qualidade da resposta.
# Pode ser um modelo diferente (geralmente mais forte) do agente.
# Baixe antes com: ollama pull llama3.1:8b
JUDGE_MODEL=qwen2.5-coder:7b

# 1 = judge ativado (padrão), 0 = desligado
USE_JUDGE=1